{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["src/**", "tsconfig.json", "vite.config.*", "svelte.config.*"],
			"outputs": ["dist/**", "build/**", ".svelte-kit/**"]
		},
		"dev": {
			"dependsOn": ["^build"],
			"cache": false,
			"persistent": true
		},
		"lint": {
			"dependsOn": ["^build"],
			"inputs": ["src/**", "eslint.config.*"]
		},
		"test": {
			"dependsOn": ["^build"],
			"inputs": ["src/**", "tests/**", "vitest.config.*"]
		},
		"test:e2e": {
			"dependsOn": ["build"],
			"inputs": ["src/**", "tests/**", "playwright.config.*"]
		},
		"test:visual": {
			"dependsOn": ["build"],
			"inputs": ["src/**", "tests/**", "playwright.config.*"]
		},
		"test:bench": {
			"dependsOn": ["^build"],
			"inputs": ["src/**", "tests/**"]
		},
		"typecheck": {
			"dependsOn": ["^build"],
			"inputs": ["src/**", "tsconfig.json"]
		}
	}
}
